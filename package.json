  "author": "euro_Office",
  "license": "AGPL-3.0",
  "dependencies": {
    "axios": "^1.6.0",
    "dockerode": "^4.0.0",
    "dotenv": "^16.3.1",
    "gifenc": "^1.0.3",
    "png-js": "^1.0.0",
    "selfsigned": "^5.5.0",
    "wait-on": "^7.2.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@playwright/test": "^1.59.1",
    "eslint": "^8.54.0",
    "jest": "^29.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
