{
  "name": "@euro-office/testsuite",
  "version": "1.0.0",
  "description": "End-to-end test suite for euro_Office integration components",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:e2e": "jest --testPathPattern=tests/e2e",
    "test:health": "jest --testPathPattern=tests/e2e/health",
    "test:wopi": "jest --testPathPattern=tests/e2e/wopi",
    "test:api": "jest --testPathPattern=tests/e2e/api",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [
    "euro-office",
    "e2e",
    "tests",
    "wopi",
    "ocis",
    "document-server"
