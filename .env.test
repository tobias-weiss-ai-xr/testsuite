# euro_Office Test Suite - Environment Configuration
# Copy this file to .env for local testing

# =============================================================================
# Service URLs (default: localhost for local Docker Compose stack)
# =============================================================================

# Document Server (WOPI client)
DOCUMENT_SERVER_URL=http://localhost:8080
DOCUMENT_SERVER_INTERNAL_URL=http://documentserver:80

# OCIS (ownCloud Infinite Scale - WOPI host)
OCIS_URL=http://localhost:9200
OCIS_INTERNAL_URL=http://ocis:9200

# eurooffice-opencloud Companion
COMPANION_URL=http://localhost:3000
COMPANION_INTERNAL_URL=http://companion:3000

# =============================================================================
# JWT Secrets (minimum 32 characters)
# =============================================================================

# OCIS JWT secret for WOPI authentication
# Generate with: openssl rand -base64 32
OCIS_JWT_SECRET=test_ocis_jwt_secret_placeholder_change_in_production

# Document Server JWT secret
# Generate with: openssl rand -base64 32
DOCUMENT_SERVER_JWT_SECRET=test_ds_jwt_secret_placeholder_change_in_production

# =============================================================================
# Test Configuration
# =============================================================================

# Docker Compose file for test stack
DOCKER_COMPOSE_FILE=docker-compose.test.yml

# Health check timeout (ms) - 2 minutes per service
HEALTH_CHECK_TIMEOUT=120000

# Global test suite timeout (ms) - 10 minutes total
GLOBAL_TIMEOUT=600000

# Maximum retries for health checks
HEALTH_CHECK_RETRIES=30

# Delay between health check retries (ms)
HEALTH_CHECK_INTERVAL=10000

# =============================================================================
# Test Data
# =============================================================================

# Test user credentials for OCIS
TEST_USER=admin
TEST_PASSWORD=admin

# Test file directory
TEST_FILES_DIR=./tests/fixtures/files
